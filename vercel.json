{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/ai-predictions",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reminder-dispatch",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/payment-reconciliation",
      "schedule": "*/30 * * * *"
    }
  ]
}
